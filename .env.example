# ─────────────────────────────────────────────
#  AI Job Application Agent — Environment Config
# ─────────────────────────────────────────────

# === REQUIRED ===
GEMINI_API_KEY=AIzaSyBKB8DCGhKWfQcE5Pmy985B6szcuCjgRvo
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# === Memory / Storage ===
DATA_DIR=./data
FAISS_INDEX_PATH=./data/faiss_index
SQLITE_DB_PATH=./data/applications.db

# === Email (optional — for Application Agent) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM_NAME=Your Name

# === Web Scraping ===
SCRAPER_TIMEOUT=30
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; JobAgent/1.0)

# === Feature Flags ===
ENABLE_BROWSER_AUTOMATION=false
ENABLE_EMAIL_SEND=false
ENABLE_CRITIC_LOOP=true
MAX_RETRIES=3
